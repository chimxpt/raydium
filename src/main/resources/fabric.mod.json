{
  "schemaVersion": 1,
  "id": "raydium",
  "version": "${version}",

  "name": "Raydium",
  "description": "Native Vulkan path tracing for Minecraft: real-time ray traced shadows, reflections and colored light with NVIDIA DLSS Ray Reconstruction. Based on VulkanMod by xCollateral.",
  "authors": [
    "chimx",
    "xCollateral (VulkanMod)"
  ],
  "contact": {
    "homepage": "",
    "sources": "https://github.com/xCollateral/VulkanMod"
  },

  "icon": "assets/vulkanmod/raydium_logo.png",

  "environment": "client",
  "entrypoints": {
    "client": [
      "net.vulkanmod.Initializer"
    ]
  },
  "mixins": [
    "vulkanmod.mixins.json"
  ],
  "accessWidener" : "vulkanmod.accesswidener",

  "depends": {
    "fabricloader": ">=0.14.14",
    "minecraft": "1.21.11"
  },
  "custom": {
    "fabric-renderer-api-v1:contains_renderer": true
  }
}
